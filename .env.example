# Torch frontend environment.
# Copy to `.env` and fill in your own Supabase project values.
# All VITE_* vars are baked into the client bundle at build time, so only put
# public/publishable values here — never a service-role or secret key.

# Supabase project reference (the part before .supabase.co)
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# Supabase publishable (anon) key — safe to expose in the browser
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxx"

# Supabase project URL
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Base URL of the public API (Supabase Edge Functions)
VITE_API_BASE="https://your-project-ref.supabase.co/functions/v1"

# Reown (WalletConnect) project id — powers the unified EVM + Solana wallet modal.
# Create one for free at https://dashboard.reown.com
VITE_REOWN_PROJECT_ID="your-reown-project-id"

# Optional: browser RPC for the Solana wallet adapter (defaults to mainnet-beta)
# VITE_SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
